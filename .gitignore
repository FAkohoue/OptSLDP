# ==============================================================================
# .gitignore for OptSLDP
# Covers: R session artefacts, R CMD check output, pkgdown build artefacts,
#         GDS intermediate files, OS and editor noise, and CI cache.
# ==============================================================================


# -- R session artefacts -------------------------------------------------------
.Rproj.user
.Rhistory
.RData
.Ruserdata
*.Rproj


# -- R CMD check and build output ----------------------------------------------
*.Rcheck/
*.tar.gz
*.zip

# Vignette build artefacts
vignettes/*.html
vignettes/*.pdf
vignettes/cache/
vignettes/figure/
vignettes/*_cache/
vignettes/*_files/

# knitr cache in root
cache/
figure/
*_cache/
*_files/

# -- Compiled C++ code (src/ld_kernel.cpp -> shared library) ------------------
# Object files and shared libraries produced during R CMD INSTALL
# NOTE: src/Makevars.win IS committed -- it is needed to link BLAS on Windows
src/*.o
src/*.so
src/*.dll
src/*.a
src/*.def
# RcppExports.R and src/RcppExports.cpp are auto-generated by
# Rcpp::compileAttributes() and ARE committed (they are source files).


# -- pkgdown site build --------------------------------------------------------
# pkgdown::build_site() writes to docs/ -- uploaded as Pages artefact by CI.
# Uncomment the next line to also exclude docs/ from git (CI-only workflow):
#docs/

# pkgdown internal reference cache
pkgdown/reference/


# -- R package example data ----------------------------------------------------
# data/example_optsldp.rda IS committed -- it is the package example dataset.
# Only ignore outputs generated by data-raw/ scripts.
data-raw/output/


# -- GDS intermediate files ----------------------------------------------------
# SNPRelate GDS files written during large-panel runs
*.gds


# -- Temporary files -----------------------------------------------------------
pruning_stats*.csv
pruning_summary*.txt
*_pruned.csv
*_pruned.hmp.txt
*pruned*.csv
*pruned*.txt


# -- Test artefacts ------------------------------------------------------------
tests/testthat/_snaps/
tests/testthat/Rplots.pdf


# -- OS noise ------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.nfs*


# -- Editor and IDE ------------------------------------------------------------
# RStudio
.Rproj.user/

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
.netrwhist

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace


# -- GitHub Actions CI cache ---------------------------------------------------
.github/caches/


# -- Miscellaneous R package development files ---------------------------------
# roxygen2 generates NAMESPACE and man/ -- both ARE committed.
# Do NOT ignore man/ or NAMESPACE.

# covr / coverage reports
coverage.xml
cobertura.xml
*.covr.rds

# profiling output
*.prof

# renv (not currently used)
renv/library/
renv/staging/
renv/.gitignore

# pak cache
pkg/

# Scratch / local experiment files
scratch/
local/
tmp/
temp/
