# ==============================================================================
# .gitignore for OptSLDP
# Covers: R session artefacts, R CMD check output, pkgdown build artefacts,
#         GDS intermediate files, OS and editor noise, and CI cache.
# ==============================================================================


# ── R session artefacts ───────────────────────────────────────────────────────
.Rproj.user
.Rhistory
.RData
.Ruserdata
*.Rproj


# ── R CMD check and build output ──────────────────────────────────────────────
# Produced by R CMD build, R CMD check, devtools::check(), rcmdcheck::rcmdcheck()
*.Rcheck/
*.tar.gz
*.zip

# Vignette build artefacts (knitr cache and intermediate files)
vignettes/*.html
vignettes/*.pdf
vignettes/cache/
vignettes/figure/
vignettes/*_cache/
vignettes/*_files/

# knitr cache in the root (when knitting outside vignettes/)
cache/
figure/
*_cache/
*_files/

# Compiled code (if package ever adds src/)
src/*.o
src/*.so
src/*.dll


# ── pkgdown site build ────────────────────────────────────────────────────────
# pkgdown::build_site() writes to docs/ by default.
# The GitHub Actions workflow uploads docs/ as a Pages artefact — it does NOT
# need to be committed.  Keep it out of version control.
docs/

# pkgdown internal reference cache (speeds up re-builds, not needed in git)
pkgdown/reference/


# ── Binary R datasets generated by data-raw/ ─────────────────────────────────
# data/example_optsldp.rda is generated by running generate_example_data.R.
# Committing binary blobs inflates repository size; regenerate on demand.
data/
data-raw/output/


# ── GDS intermediate files ────────────────────────────────────────────────────
# SNPRelate GDS files are written to gds_dir (default: tempdir()) during
# large-panel runs.  Any that land in the working directory should be ignored.
*.gds


# ── Temporary files written by run_sldp() and tests ──────────────────────────
# Pruning statistics CSV and plain-text summary outputs
pruning_stats*.csv
pruning_summary*.txt

# Temporary genotype output files produced during testing or interactive use
*_pruned.csv
*_pruned.hmp.txt
*pruned*.csv
*pruned*.txt


# ── Test artefacts ────────────────────────────────────────────────────────────
# testthat snapshot files (generated by expect_snapshot())
tests/testthat/_snaps/

# testthat temporary files
tests/testthat/Rplots.pdf


# ── OS noise ──────────────────────────────────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.nfs*


# ── Editor and IDE noise ──────────────────────────────────────────────────────
# RStudio
*.Rproj
.Rproj.user/

# VS Code
.vscode/
*.code-workspace

# JetBrains (RStudio Positron, etc.)
.idea/
*.iml
*.iws

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace


# ── GitHub Actions CI cache ───────────────────────────────────────────────────
# The Actions cache is stored on GitHub's servers, not in the repo.
# Local runner cache directories (uncommon but possible in self-hosted setups)
.github/caches/


# ── Miscellaneous R package development files ─────────────────────────────────
# roxygen2 generates NAMESPACE and man/ — both ARE committed.
# Do NOT ignore man/ or NAMESPACE.

# covr / coverage reports
coverage.xml
cobertura.xml
*.covr.rds

# profvis / profiling output
*.prof

# renv (if ever adopted — not currently used)
renv/library/
renv/staging/
renv/.gitignore

# pak cache (used by r-lib/actions)
pkg/

# Scratch / local experiment files
scratch/
local/
tmp/
temp/
